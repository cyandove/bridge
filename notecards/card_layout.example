# card_layout notecard -- dummy hand prim positioning
# Copy this file's contents into a notecard named "card_layout" and drop it
# into the same prim as card_display.lsl. The script reloads automatically
# when the notecard changes.
#
# Positions and spreads are <x,y,z> vectors in local space (relative to the
# table root prim). Rotations are <x,y,z,w> quaternions.
#
# To find the right values: edit the table, select the root prim, then use
# a temporary helper prim to measure local coordinates where you want the
# first card (dummy_0) of each dummy seat to appear.

north_base=<-0.72,1.10,0.02>
north_spread=<0.12,0.0,0.0>
north_rot=<0.0,0.0,0.0,1.0>

south_base=<-0.72,-1.10,0.02>
south_spread=<0.12,0.0,0.0>
south_rot=<0.0,0.0,1.0,0.0>

east_base=<1.10,-0.72,0.02>
east_spread=<0.0,0.12,0.0>
east_rot=<0.0,0.0,0.707,0.707>

west_base=<-1.10,-0.72,0.02>
west_spread=<0.0,0.12,0.0>
west_rot=<0.0,0.0,-0.707,0.707>
